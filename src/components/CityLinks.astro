---
/**
 * CityLinks.astro â€” full city list.
 * - No `service`: links to city hubs (/service-area/{city}/).
 * - With `service`: links to that service's combo page in each city.
 * `exclude` drops one city slug (e.g. the current city).
 */
import { CITIES } from '@config/cities';
import { SITE } from '@config/site';
import type { Service } from '@config/services';
import { cityUrl, cityServiceUrl } from '../lib/urls';

interface Props {
  service?: Service;
  exclude?: string;
  title?: string;
  sub?: string;
}
const { service, exclude, title, sub } = Astro.props;

const list = CITIES.filter((c) => c.slug !== exclude);
const headTitle =
  title ?? (service ? `${service.short} by Town` : 'Towns We Serve');

// EXP-003 (see analytics/analysis/ONPAGE-EXPERIMENTS.md): give city-hub internal links
// service-qualified anchor text ("Brake Repair in Boerne") instead of the bare city name,
// so each city hub earns exact-match anchors for "{trade} {city}" queries. Title-case the
// lowercase prose trade ("brake repair" -> "Brake Repair").
const tradeLabel = SITE.trade.replace(/\b\w/g, (m) => m.toUpperCase());
---

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <h2>{headTitle}</h2>
      {sub && <p class="lead muted">{sub}</p>}
    </div>
    <ul class="cities">
      {
        list.map((c) => (
          <li>
            <a href={service ? cityServiceUrl(service, c) : cityUrl(c)}>
              {service ? `${service.short} in ${c.name}` : `${tradeLabel} in ${c.name}`}
              <small>{c.state ? c.state : ''}</small>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
